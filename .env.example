# 知源 (KnowSource) 环境变量配置示例
# 复制此文件为 .env 并按需修改（Electron 桌面应用通常无需手动配置）

# 数据存储目录（Electron 自动设为 userData 目录，独立运行后端时需手动指定）
# KNOWLEDGE_IDE_DATA_DIR=~/.knowledge-ide/data

# 后端服务端口（默认 8000）
# PORT=8000

# 禁用数据持久化（仅用于调试，设为 1 时所有数据仅存内存）
# KNOWLEDGE_IDE_NO_PERSIST=0

# 本地 API 认证令牌（Electron 自动生成，独立运行后端时可手动指定）
# KNOWLEDGE_IDE_API_TOKEN=
