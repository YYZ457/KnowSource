{
  "name": "knowsource",
  "version": "2.2.0",
  "description": "知源 KnowSource — 科研知识工作台：PDF 文档解析、知识图谱构建、LLM 辅助分析",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"vite\"",
    "dev:backend": "node services/server.js",
    "dev:electron": "concurrently \"npm run dev:backend\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:all": "vite build && electron-builder -mwl",
    "test": "node --test tests/ || echo 'No tests found, skipping'"
  },
  "build": {
    "appId": "com.knowsource.desktop",
    "productName": "知源",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "services/**",
      "core/**",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "sample_docs",
        "to": "sample_docs",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "知源"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YYZ457/KnowSource.git"
  },
  "homepage": "https://github.com/YYZ457/KnowSource",
  "bugs": {
    "url": "https://github.com/YYZ457/KnowSource/issues"
  },
  "keywords": [
    "knowledge-graph",
    "pdf",
    "research",
    "ollama",
    "llm",
    "electron",
    "vue",
    "knowledge-management"
  ],
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dompurify": "^3.4.11",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.2.0",
    "pdfjs-dist": "^3.11.174",
    "pinia": "^2.1.0",
    "splitpanes": "^4.1.2",
    "tesseract.js": "^5.1.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "sharp": "^0.35.3",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "author": "YYZ457",
  "license": "MIT"
}
